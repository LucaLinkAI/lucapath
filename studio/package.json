{
  "name": "lucapath-studio",
  "private": true,
  "version": "0.1.0",
  "description": "LucaPath Studio — local webapp wrapping the destiny-report skills behind a Claude-style chat UI",
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "npm --workspace server run dev",
    "dev:client": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "start": "npm --workspace server run start"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
